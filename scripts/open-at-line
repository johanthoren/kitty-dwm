#!/usr/bin/env python3
"""Open a file in nvim, optionally at line. Argv-safe (no shell).

Accepts either:
  open-at-line path
  open-at-line path:line
  open-at-line path line
"""

from __future__ import annotations

import os
import sys


def parse(argv: list[str]) -> tuple[str, str | None]:
    if len(argv) >= 3 and argv[2].isdigit():
        return argv[1], argv[2]
    if len(argv) >= 2:
        spec = argv[1]
        if ":" in spec:
            path, maybe_line = spec.rsplit(":", 1)
            if maybe_line.isdigit() and path:
                return path, maybe_line
        return spec, None
    raise SystemExit("usage: open-at-line <path[:line]> | <path> <line>")


def main() -> None:
    path, line = parse(sys.argv)
    if not path:
        raise SystemExit("empty path")
    args = ["nvim"]
    if line is not None:
        args.append(f"+{line}")
    args.extend(["--", path])
    os.execvp("nvim", args)


if __name__ == "__main__":
    main()
