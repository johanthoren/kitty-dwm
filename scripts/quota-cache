#!/usr/bin/env python3
"""Cache OpenAI, Claude, and Grok subscription usage for kitty's tab bar."""

import json
import os
import subprocess
import sys
import tempfile
import time
import urllib.request
from datetime import datetime
from pathlib import Path
from typing import Any

CACHE_DIR = Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache")) / "kitty-dwm"
WINDOWS = {"5h": "fiveHour", "7d": "weekly"}
GROK_BILLING_URL = "https://cli-chat-proxy.grok.com/v1/billing"


def write_cache(name: str, data: dict[str, Any]) -> None:
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    descriptor, temporary = tempfile.mkstemp(dir=CACHE_DIR, prefix=f".{name}.")
    try:
        with os.fdopen(descriptor, "w") as output:
            json.dump(data, output, separators=(",", ":"))
        os.replace(temporary, CACHE_DIR / name)
    except BaseException:
        Path(temporary).unlink(missing_ok=True)
        raise


def parse_window(limit: dict[str, Any]) -> tuple[str, dict[str, float]] | None:
    scope = limit.get("scope") or {}
    window_id = scope.get("windowId")
    amount = limit.get("amount") or {}
    reset = (limit.get("window") or {}).get("resetsAt")
    if window_id not in WINDOWS or scope.get("tier"):
        return None
    used_fraction = amount.get("usedFraction")
    if used_fraction is None and amount.get("used") is not None and amount.get("limit"):
        used_fraction = float(amount["used"]) / float(amount["limit"])
    if used_fraction is None or reset is None:
        return None
    return WINDOWS[window_id], {
        "usedPercentage": float(used_fraction) * 100,
        "resetsAt": float(reset) / 1000,
    }


def cache_openai() -> None:
    result = subprocess.run(
        ["/bin/zsh", "-ic", "exec omp usage --provider openai-codex --json"],
        check=True,
        capture_output=True,
        text=True,
        timeout=15,
    )
    payload = json.loads(result.stdout)
    reports = payload.get("reports") or []
    if not reports:
        raise RuntimeError("OMP returned no OpenAI usage report")

    windows = dict(filter(None, (parse_window(limit) for limit in reports[0].get("limits", []))))
    if not windows:
        raise RuntimeError("OMP returned no supported OpenAI quota windows")
    write_cache("openai-usage.json", {"updatedAt": time.time(), **windows})


def parse_iso_timestamp(value: str) -> float:
    return datetime.fromisoformat(value.replace("Z", "+00:00")).timestamp()


def grok_window(used_percentage: float, resets_at: str) -> dict[str, float]:
    return {
        "usedPercentage": max(0.0, min(100.0, float(used_percentage))),
        "resetsAt": parse_iso_timestamp(resets_at),
    }


def cache_grok() -> None:
    token = subprocess.run(
        ["/bin/zsh", "-ic", "exec omp token xai-oauth --raw"],
        check=True,
        capture_output=True,
        text=True,
        timeout=15,
    ).stdout.strip()
    if not token:
        raise RuntimeError("OMP returned no xai-oauth token")

    headers = {
        "Authorization": f"Bearer {token}",
        "Accept": "application/json",
        "User-Agent": "kitty-dwm/quota-cache",
    }

    def fetch(url: str) -> dict[str, Any]:
        request = urllib.request.Request(url, headers=headers)
        with urllib.request.urlopen(request, timeout=15) as response:
            return json.load(response)

    monthly = (fetch(GROK_BILLING_URL).get("config") or {})
    credits = (fetch(f"{GROK_BILLING_URL}?format=credits").get("config") or {})
    windows: dict[str, dict[str, float]] = {}

    used = (monthly.get("used") or {}).get("val")
    limit = (monthly.get("monthlyLimit") or {}).get("val")
    month_end = monthly.get("billingPeriodEnd")
    if used is not None and limit and month_end:
        windows["monthly"] = grok_window(100.0 * float(used) / float(limit), month_end)

    week_end = (credits.get("currentPeriod") or {}).get("end") or credits.get("billingPeriodEnd")
    week_used = credits.get("creditUsagePercent")
    if week_used is not None and week_end:
        windows["weekly"] = grok_window(float(week_used), week_end)

    if not windows:
        raise RuntimeError("Grok billing returned no supported quota windows")
    write_cache("grok-usage.json", {"updatedAt": time.time(), **windows})


def parse_claude_window(rate_limits: dict[str, Any], source: str) -> dict[str, float] | None:
    window = rate_limits.get(source) or {}
    used = window.get("used_percentage")
    reset = window.get("resets_at")
    if used is None or reset is None:
        return None
    return {"usedPercentage": float(used), "resetsAt": float(reset)}


def cache_claude() -> None:
    rate_limits = (json.load(sys.stdin).get("rate_limits") or {})
    windows = {
        name: window
        for name, source in (("fiveHour", "five_hour"), ("weekly", "seven_day"))
        if (window := parse_claude_window(rate_limits, source)) is not None
    }
    if windows:
        write_cache("claude-usage.json", {"updatedAt": time.time(), **windows})


def main() -> None:
    if sys.argv[1:] == ["--claude"]:
        cache_claude()
    elif sys.argv[1:]:
        raise SystemExit("usage: quota-cache [--claude]")
    else:
        errors = []
        for name, fn in (("openai", cache_openai), ("grok", cache_grok)):
            try:
                fn()
            except Exception as exc:  # keep the other provider's cache warm
                errors.append(f"{name}: {exc}")
        if len(errors) == 2:
            raise SystemExit("; ".join(errors))


if __name__ == "__main__":
    main()
